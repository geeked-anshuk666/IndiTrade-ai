# -----------------------------------------------------------------------------
# IndiTrade-ai: Environment Template
# Copy this file to .env and fill in your keys.
# -----------------------------------------------------------------------------

# --- [REQUIRED] ---
# Get your free key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# A unique 32+ character string used to sign your tokens. 
# You can generate one with: openssl rand -hex 32
JWT_SECRET="your-random-32-character-secret-here"

# --- [OPTIONAL: API Behavior] ---
# CORS: Use "*" for testing, or your production domain for security.
ALLOWED_ORIGINS="*"

# How long a "Guest Session" token remains valid (in minutes).
JWT_EXPIRY_MINUTES=60

# --- [OPTIONAL: Rate Limiting] ---
# Formats: "5/minute", "1/second", etc.
RATE_LIMIT_ANALYZE="5/minute"
RATE_LIMIT_AUTH="10/minute"
